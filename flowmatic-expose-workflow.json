      "id": "n-post",
      "name": "POST — Exposé generieren",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        100,
        500
      ],
      "webhookId": "flowmatic-expose-post"
    },
    {
      "parameters": {
        "jsCode": "// ══ NODE 02 · VALIDIERUNG ══════════════════════════════════════════════\nconst body = $input.first().json.body || $input.first().json;\nconst e = [];\n\nconst req = {typ:'Objekttyp',ang:'Angebotstyp',adr:'Adresse',fl:'Wohnfläche',zi:'Zimmer',pr:'Preis',zu:'Zustand'};\nfor(const [k,l] of Object.entries(req)){\n  if(!body[k]||String(body[k]).trim()==='') e.push('Pflichtfeld fehlt: '+l);\n}\n\nif(body.fl && parseFloat(body.fl)<5) e.push('Wohnfläche zu klein');\nif(body.bj && (parseInt(body.bj)<1800||parseInt(body.bj)>2030)) e.push('Baujahr ungültig');\n\nif(e.length>0) return [{ json:{_err:true,step:'Validierung',error:e.join(' | ')} }];\n\nconst bilder=(Array.isArray(body.bilder)?body.bilder:[]).slice(0,10).filter(b=>b&&b.data&&b.data.length>100);\n\nreturn [{ json:{ body, bilder, ok:true } }];"
      },
      "id": "n2",
      "name": "02 · Eingabe validieren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// ══ NODE 03 · DATEN + PROMPTS AUFBAUEN ════════════════════════════════\nconst input = $input.first().json;\nif(input._err) return [{ json:input }];\n\nconst b = input.body;\nconst bilder = input.bilder || [];\n\nconst preisN = parseInt(String(b.pr).replace(/[^0-9]/g,''));\nconst preisFmt = new Intl.NumberFormat('de-CH').format(preisN);\nconst preisLbl = b.ang==='Vermietung' ? 'Mietzins' : 'Kaufpreis';\n\nconst kantone={ZH:'Zürich',ZG:'Zug',BS:'Basel-Stadt',GE:'Genf',BE:'Bern',LU:'Luzern',AG:'Aargau',SZ:'Schwyz',SG:'St. Gallen',GR:'Graubünden',TG:'Thurgau',TI:'Tessin',VD:'Waadt',VS:'Wallis',FR:'Freiburg'};\nconst ktName = kantone[b.kt] || b.kt || '';\nconst adresse = b.adr + (ktName ? ', '+ktName : '');\n\nconst alter = b.bj ? (2025-parseInt(b.bj)) : null;\nconst alterTxt = alter===null?'':alter<=0?'Neubau':alter<=5?'nahezu neu':alter+' Jahre alt';\nconst renoTxt = b.re ? (2025-parseInt(b.re)<=3?'kürzlich renoviert':'Renovation '+b.re) : '';\n\nconst merkmale = Array.isArray(b.merkmale)&&b.merkmale.length>0 ? b.merkmale.join(', ') : 'keine';\n\nconst bildInfo = bilder.length>0\n  ? bilder.length+' Bild'+(bilder.length>1?'er':'')+': '+bilder.map((bi,i)=>bi.label||'Bild '+(i+1)).join(', ')\n  : 'keine Bilder';\n\nconst stilMap = {\n  'Professionell':'Sachlich, präzise, seriös. Fakten im Vordergrund.',\n  'Emotional':'Wärmend, einladend. Lässt den Leser sich vorstellen, dort zu leben.',\n  'Premium':'Exklusiv, distinguiert. Für anspruchsvolle Käufer.',\n  'Familiär':'Herzlich, praktisch. Alltag und Familie betonen.'\n};\nconst zgMap = {\n  'Familien':'Betone Schulen, Garten, Platz, Gemeinschaft.',\n  'Paare / Singles':'Betone Lage, Lifestyle, moderne Küche.',\n  'Investoren':'Betone Rendite, Substanz, Lage-Entwicklung.',\n  'Keine Vorgabe':'Breite Ansprache, kein Fokus.'\n};\n\nconst systemPrompt = `Du bist der beste Immobilien-Texter der Schweiz.\nSchweizer Hochdeutsch. Keine Klischees. Keine leeren Versprechen. Jeder Satz trägt.\nStil: ${stilMap[b.ton]||stilMap['Professionell']}\nZielgruppe: ${zgMap[b.zg]||zgMap['Keine Vorgabe']}\n\nGib exakt diese zwei Blöcke aus:\n===VOLLSTAENDIG===\n[500–700 Wörter: emotionaler Einstieg, alle Details eingeflochten, Bilder präzise beschrieben]\n===PORTAL===\n[Max. 1800 Zeichen: kompakt, alle Pflichtinfos, für ImmoScout24 und Homegate optimiert]`;\n\nconst userPrompt = `OBJEKT: ${b.typ} | ${b.ang} | ${adresse}\nFLÄCHE: ${b.fl} m² | ZIMMER: ${b.zi}${b.st_?' | '+b.st_:''}\nBAUJAHR: ${b.bj||'–'}${alterTxt?' ('+alterTxt+')':''}${renoTxt?' | '+renoTxt:''}\n${preisLbl}: CHF ${preisFmt}\nZUSTAND: ${b.zu} | HEIZUNG: ${b.hz||'–'} | PARKIERUNG: ${b.pk||'keine'}\nMERKMALE: ${merkmale}\nWEITERE DETAILS: ${b.we||'keine'}\nLAGE: ${b.um||'–'}\nÖV: ${b.ov||'–'} | EINKAUF/SCHULEN: ${b.sc||'–'}\nBILDER: ${bildInfo}\n\nAnalysiere zuerst die Bilder und integriere visuelle Details natürlich in beide Texte.`;\n\nreturn [{ json:{ ...input, systemPrompt, userPrompt, preisFmt, adresse } }];"
      },
      "id": "n3",
      "name": "03 · Prompts aufbauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// ══ NODE 04 · CLAUDE MESSAGE BAUEN ════════════════════════════════════\nconst input = $input.first().json;\nif(input._err) return [{ json:input }];\n\nconst bilder = input.bilder || [];\nconst content = [];\n\nfor(const bild of bilder){\n  content.push({ type:'image', source:{ type:'base64', media_type:bild.type||'image/jpeg', data:bild.data } });\n  content.push({ type:'text', text:'↑ '+( bild.label||'Immobilienbild') });\n}\ncontent.push({ type:'text', text:input.userPrompt });\n\nreturn [{ json:{ ...input, apiBody:{\n  model:'claude-sonnet-4-6',\n  max_tokens:3000,\n  system:input.systemPrompt,\n  messages:[{ role:'user', content }]\n} } }];"
      },
      "id": "n4",
      "name": "04 · Claude Message bauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
