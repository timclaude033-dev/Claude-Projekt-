    {
      "parameters": {
        "jsCode": "// ══ NODE 06 · ANTWORT VERARBEITEN ═════════════════════════════════════\nconst r = $input.first().json;\n\nif(r.error){\n  const codes = {\n    'authentication_error':'Ungültiger API Key — bitte CLAUDE_API_KEY in n8n prüfen.',\n    'rate_limit_error':'Rate Limit — bitte 60 Sek. warten.',\n    'overloaded_error':'Claude überlastet — bitte erneut versuchen.'\n  };\n  return [{ json:{ success:false, error:codes[r.error.type]||'API Fehler: '+r.error.message } }];\n}\n\nconst raw = r.content?.[0]?.text||'';\nif(!raw) return [{ json:{ success:false, error:'Keine Antwort von Claude — bitte erneut versuchen.' } }];\n\nfunction extr(text, start, end){\n  const si=text.indexOf(start);\n  if(si===-1) return null;\n  const after=text.slice(si+start.length);\n  if(!end) return after.trim();\n  const ei=after.indexOf(end);\n  return ei===-1?after.trim():after.slice(0,ei).trim();\n}\n\nlet vollst = extr(raw,'===VOLLSTAENDIG===','===PORTAL===') || raw.trim();\nlet portal = extr(raw,'===PORTAL===',null) || vollst.slice(0,1800);\n\n// Portal auf 1800 Zeichen kürzen (sauber auf Satz)\nif(portal.length>1800){\n  let cut=portal.slice(0,1780);\n  const last=Math.max(cut.lastIndexOf('.'),cut.lastIndexOf('!'),cut.lastIndexOf('?'));\n  portal=last>1600?cut.slice(0,last+1):cut.trim()+'...';\n}\n\nreturn [{ json:{ success:true, vollstaendig:vollst, portal, stats:{\n  worte:vollst.split(/\\s+/).filter(w=>w).length,\n  zeichenPortal:portal.length\n} } }];"
      },
